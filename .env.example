# =============================================================================
# Hostinger: set these in Node.js → Environment Variables, then Redeploy/Rebuild.
# Git deploys do NOT include .env.local (gitignored) — panel env can also reset
# on redeploy. After pasting values, rebuild so NEXT_PUBLIC_* are baked in.
# =============================================================================

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_SECRET_KEY=sk_live_your_key_here
# Apple Pay (web), either:
# - paste full file contents (Stripe Dashboard download), or
# - save file as public/.well-known/apple-developer-merchantid-domain-association
STRIPE_APPLE_PAY_DOMAIN_ASSOCIATION=

ADMIN_USERNAME=riverdale
ADMIN_PASSWORD=riverdale123
ADMIN_SESSION_SECRET=replace-with-long-random-secret

# Resend email (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM=Café Riverdale <orders@riverdalecafe.com.au>
RESEND_NOTIFY_TO=subedi9aseem@gmail.com,ashish@movoc.com
EMAIL_NOTIFY_ENABLED=true

# WhatsApp / SMS order alerts (optional — Twilio)
WHATSAPP_NOTIFY_ENABLED=true
TWILIO_ACCOUNT_SID=ACxxxxxxxx
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_NOTIFY_TO=whatsapp:+61400000000
TWILIO_SMS_FROM=+17626003093
TWILIO_SMS_NOTIFY_TO=+61400000000
# CallMeBot (free alternative): https://www.callmebot.com/blog/free-api-whatsapp-messages/
CALLMEBOT_PHONE=61400000000
CALLMEBOT_API_KEY=

# Store + maps (required for address / delivery distance)
NEXT_PUBLIC_STORE_LAT=-37.834434
NEXT_PUBLIC_STORE_LNG=144.651042
NEXT_PUBLIC_DELIVERY_RADIUS_BUFFER_KM=0.2
NEXT_PUBLIC_STORE_RADIUS_KM=5
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_DISTANCE_MODE=driving
